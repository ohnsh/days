---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import Day from '@/components/DayContent.astro'
import { getFilteredDayMap, tagDayMap } from '@/lib/days'
import { titleFromDay, slugFromDay } from '@/lib/dates'
import { sidebarFrom } from '@/lib/sidebar'

export async function getStaticPaths() {
  const dayMap = await getFilteredDayMap()
  const tags = (await tagDayMap).keys()
  const sidebar = sidebarFrom([...dayMap.keys()], [...tags])

  const paths = dayMap
    .entries()
    .map(([dayKey, dayEntry]) => ({
      params: { slug: slugFromDay(dayKey) },
      props: { day: dayEntry, sidebar },
    }))

  return [...paths]
}

const { day, sidebar } = Astro.props
const title = titleFromDay(day.key)
const frontmatter = { title }

Object.assign(Astro.locals, { days: { day }})
---

<StarlightPage {sidebar} {frontmatter}>
  <Day {day} />
</StarlightPage>
