---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import Day from '@/components/Day.astro'
import { getDayMap, sidebarFromKeys, slugFromDate } from '@/lib/pathsUtil'
import type { InferGetStaticPropsType } from 'astro'

export async function getStaticPaths() {
  const dayMap = await getDayMap()
  const sidebar = sidebarFromKeys([...dayMap.keys()], { collapsed: true })

  const paths = dayMap
    .entries()
    .map(([dayKey, dayEntry]) => ({
      params: { slug: slugFromDate(dayKey) },
      props: { day: dayEntry, sidebar },
    }))

  return [...paths]
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>

const { slug } = Astro.params
const { day, sidebar } = Astro.props
const frontmatter = { title: slug }
---

<StarlightPage {sidebar} {frontmatter}>
  <Day {day} />
</StarlightPage>
