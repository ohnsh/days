---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import Day from '@/components/Day.astro'
import { getFilteredDayMap } from '@/lib/days'
import type { InferGetStaticPropsType } from 'astro'
import { titleFromDayKey, slugFromDate } from '@/lib/dates'
import { sidebarFromKeys } from '@/lib/sidebar'

export async function getStaticPaths() {
  const dayMap = await getFilteredDayMap()
  const sidebar = sidebarFromKeys([...dayMap.keys()], { collapsed: true })

  const paths = dayMap
    .entries()
    .map(([dayKey, dayEntry]) => ({
      params: { slug: slugFromDate(dayKey) },
      props: { day: dayEntry, sidebar },
    }))

  return [...paths]
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>

const { day, sidebar } = Astro.props
const title = titleFromDayKey(day.dayKey)
const frontmatter = { title }

Object.assign(Astro.locals, { days: { day }})
---

<StarlightPage {sidebar} {frontmatter}>
  <Day {day} />
</StarlightPage>
