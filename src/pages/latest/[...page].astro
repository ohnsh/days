---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import Day from '@/components/Day.astro'
import type { GetStaticPaths } from 'astro'
import { frontmatter } from './_index.md'
import { getFilteredDayMap } from '@/lib/days'
import { sidebarFromKeys } from '@/lib/sidebar'

export const getStaticPaths = (async ({ paginate }) => {
  const dayMap = await getFilteredDayMap()
  const days = [...dayMap.values()].sort((a, b) => b.dayKey.localeCompare(a.dayKey))
  const sidebar = sidebarFromKeys([...dayMap.keys()], { collapsed: true })
  return paginate(days, { pageSize: 5, props: { sidebar } })
}) satisfies GetStaticPaths

const { page, sidebar } = Astro.props
Object.assign(Astro.locals, { days: { page } })

// const { date: firstDate } = page.data[0].data
const { title, hero } = frontmatter
---

<StarlightPage
  {sidebar}
  frontmatter={{ title, tableOfContents: false, hero: page.currentPage === 1 ? hero : undefined }}
>
  {page.data.map((day) => <Day {day} renderTitle />)}
</StarlightPage>

<style>
  hr {
    margin-block: 3rem;
    border: none;
    border-top: 1px solid var(--sl-color-gray-5);
  }
</style>
