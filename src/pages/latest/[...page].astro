---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import Day from '@/components/DayContent.astro'
import type { GetStaticPaths } from 'astro'
import { frontmatter } from './_index.md'
import { getFilteredDayMap } from '@/lib/days'
import { getSidebar } from '@/lib/sidebar'
import { getCollection } from 'astro:content'
import LatestPosts from '@/components/LatestPosts.astro'
import LatestVids from '@/components/LatestVids.astro'

export const getStaticPaths = (async ({ paginate }) => {
  function getPosts() {
    return getCollection('posts', ({ data: { draft = false } }) => !draft || import.meta.env.DEV)
  }
  const dayMap = await getFilteredDayMap()
  const days = [...dayMap.values()].sort((a, b) => b.key.localeCompare(a.key))
  const sidebar = await getSidebar()
  const latestPosts = (await getPosts())
    .sort((a, b) => -a.data.day.localeCompare(b.data.day))
    .slice(0, 5)
  return paginate(days, { pageSize: 5, props: { sidebar, latestPosts } })
}) satisfies GetStaticPaths

const { page, sidebar, latestPosts } = Astro.props
Object.assign(Astro.locals, { days: { page } })

// const { date: firstDate } = page.data[0].data
const { title, hero } = frontmatter
---

<StarlightPage
  {sidebar}
  frontmatter={{ title, tableOfContents: false, hero: page.currentPage === 1 ? hero : undefined }}
>
  {page.currentPage === 1 && <LatestPosts {latestPosts} />}
  {page.currentPage === 1 && <LatestVids />}
  {page.data.map((day) => <Day {day} renderTitle />)}
</StarlightPage>

<style>
  :global(article):not(article article, :first-of-type) {
    margin-top: 5rem;
  }
</style>
