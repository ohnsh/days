---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import type { CollectionEntry } from 'astro:content'
import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'
import { getFilteredDayMap, type DayEntry } from '@/lib/days'
import { keyFromDate } from '@/lib/dates'
import { sidebarFromKeys } from '@/lib/sidebar'
import Day from '@/components/Day.astro'

export async function getStaticPaths({ paginate }: Parameters<GetStaticPaths>[0]) {
  const posts = await getCollection('posts')
  const days = await getCollection('days')
  const dayMap = await getFilteredDayMap()
  const tagMap = new Map<string, Set<DayEntry>>()
  const extractTags = (entry: CollectionEntry<'posts'> | CollectionEntry<'days'>) => {
    const { tags } = entry.data
    if (!tags) {
      return
    }
    const key = keyFromDate(entry.data.date)
    const day = dayMap.get(key)
    if (!day) {
      console.error(`extractTags couldn't find DayEntry for key ${key}`)
      return
    }
    for (const tag of tags) {
      const days = tagMap.get(tag) ?? tagMap.set(tag, new Set).get(tag)!
      days.add(day)
    }
  }
  posts.forEach(extractTags)
  days.forEach(extractTags)
  const sidebar = sidebarFromKeys([...dayMap.keys()])
  const pathIterator = tagMap
    .entries()
    .map(([tag, days]) => ({ params: { tag }, props: { days: [...days], sidebar } }))
  return [...pathIterator]
}

const { tag } = Astro.params
const { days, sidebar } = Astro.props
// const { date: firstDate } = posts[0].data
---

<StarlightPage {sidebar} frontmatter={{ title: `tag: ${tag}`, tableOfContents: false }}>
  {days.map((day) => <Day {day} renderTitle />)}
</StarlightPage>
