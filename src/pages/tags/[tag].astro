---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { getPosts } from '@/lib/util'
import type { CollectionEntry } from 'astro:content'
import type { GetStaticPaths } from 'astro'
import Preview from '@/components/Preview.astro'

export async function getStaticPaths({ paginate }: Parameters<GetStaticPaths>[0]) {
  const posts = await getPosts()
  const tagMap = new Map<string, CollectionEntry<'docs'>[]>()
  for (const post of posts) {
    const { tags } = post.data
    if (!tags) { continue }
    for (const tag of tags) {
      const posts = tagMap.get(tag) ?? []
      posts.push(post)
      if (!tagMap.has(tag)) {
        tagMap.set(tag, posts)
      }
    }
  }
  const pathIterator = tagMap.entries().map(([tag, posts]) => ({
    params: { tag },
    props: { posts },
  }))
  return [...pathIterator]
}

const { tag } = Astro.params
const { posts } = Astro.props
const { date: firstDate } = posts[0].data
---

<StarlightPage
  frontmatter={{
    title: `tag: ${tag}`,
    date: firstDate,
    tableOfContents: false,
  }}
>
  {
    posts.map((entry) => (
      <>
        <Preview {entry} />
        <hr />
      </>
    ))
  }
  <!-- Letting Starlight render <Pagination> in the footer, where it belongs, but overriding <Pagination> to fix it with the current route. -->
</StarlightPage>

<style>
  hr {
    margin-block: 3rem;
    border: none;
    border-top: 1px solid var(--sl-color-gray-5);
  }
</style>
