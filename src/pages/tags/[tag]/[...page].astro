---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import type { GetStaticPaths } from 'astro'
import { getFilteredDayMap } from '@/lib/days'
import { sidebarFromKeys } from '@/lib/sidebar'
import Day from '@/components/Day.astro'
import { tagDayMap } from '@/lib/days'

export async function getStaticPaths({ paginate }: Parameters<GetStaticPaths>[0]) {
  const dayMap = await getFilteredDayMap()

  const sidebar = sidebarFromKeys([...dayMap.keys()])
  const pathIterator = (await tagDayMap)
    .entries()
    .flatMap(([tag, dayKeys]) =>
      paginate([...dayKeys.map((dayKey) => dayMap.get(dayKey)!)], {
        pageSize: 3,
        params: { tag },
        props: { sidebar },
      })
    )

  return [...pathIterator]
}

const { tag } = Astro.params
const { page, sidebar } = Astro.props
Object.assign(Astro.locals, { days: { page } })
// const { date: firstDate } = posts[0].data
---

<StarlightPage {sidebar} frontmatter={{ title: `tag: ${tag}`, tableOfContents: false }}>
  {page.data.map((day) => <Day {day} renderTitle />)}
</StarlightPage>

<style>
  :global(h1) {
    font-size: var(--sl-text-lg);
    margin-bottom: 0.5em;
  }
</style>
