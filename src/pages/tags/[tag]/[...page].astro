---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import type { GetStaticPaths } from 'astro'
import { getFilteredDayMap, tagDayMap } from '@/lib/days'
import { sidebarFrom } from '@/lib/sidebar'
import Day from '@/components/DayContent.astro'

export async function getStaticPaths({ paginate }: Parameters<GetStaticPaths>[0]) {
  const dayMap = await getFilteredDayMap()
  const tags = (await tagDayMap).keys()
  const sidebar = sidebarFrom([...dayMap.keys()], [...tags])
  const pathIterator = (await tagDayMap)
    .entries()
    .flatMap(([tag, dayKeys]) =>
      // TODO: make not terrible
      paginate([...dayKeys].sort().reverse().map((dayKey) => dayMap.get(dayKey)!), {
        pageSize: 5,
        params: { tag },
        props: { sidebar },
      })
    )

  return [...pathIterator]
}

const { tag } = Astro.params
const { page, sidebar } = Astro.props
Object.assign(Astro.locals, { days: { page } })
// const { date: firstDate } = posts[0].data
---

<StarlightPage {sidebar} frontmatter={{ title: `tag: ${tag}`, tableOfContents: false }}>
  {page.data.map((day) => <Day {day} renderTitle />)}
</StarlightPage>

<style>
  :global(h1) {
    font-size: var(--sl-text-lg);
    margin-bottom: 0.5em;
  }
</style>
