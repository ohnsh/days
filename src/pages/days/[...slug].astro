---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { getPosts } from '@/lib/util'
import { getCollection, render } from 'astro:content'
import GithubDay from '@/components/GithubDay.astro'
import YTDay from '@/components/YTDay.astro'

export async function getStaticPaths() {
  const [github, youtube, days] = await Promise.all([
    getCollection('github'),
    getCollection('youtube'),
    getPosts(),
  ])

  const day = {
    github: github.find(({ id }) => id === '2026-03-07'),
    youtube: youtube.find(({ id }) => id === '2026-03-07'),
    days: days.find(({ id }) => id === '2026/mar/7'),
  }
  const paths = [{ params: { slug: '2026-03-07' }, props: { day } }]

  return paths
}

const { slug } = Astro.params
const { day } = Astro.props
const { Content } = await render(day.days!)

const frontmatter = { title: slug, date: new Date(slug) }
---

<StarlightPage {frontmatter}>
  <GithubDay day={day.github} />
  <YTDay day={day.youtube} />
  <Content />
</StarlightPage>
