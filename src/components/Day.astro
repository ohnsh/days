---
import type { DayEntry } from '@/lib/pathsUtil'
import { titleFromDayKey } from '@/lib/util'
import GithubDay from '@/components/GithubDay.astro'
import YTDay from '@/components/YTDay.astro'
import Preview from './Preview.astro'

interface Props {
  day: DayEntry
  renderTitle?: boolean
}

const { day, renderTitle = false } = Astro.props
const title = titleFromDayKey(day.dayKey)
---

{renderTitle && <h2>{title}</h2>}
{day.github && <GithubDay day={day.github} />}
{day.youtube && <YTDay day={day.youtube} />}
{day.posts?.map(post => <Preview entry={post} />)}
