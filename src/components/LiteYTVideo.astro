---
import { YouTube } from '@astro-community/astro-embed-youtube'
const { title, description, videoId, publishedAt, isShort, naked = false } = Astro.props
const date = new Date(publishedAt).toLocaleDateString('en-US', { dateStyle: 'medium' })
---

<figure>
  <YouTube id={videoId} {title} posterQuality="max" />
  {
    !naked && (
      <figcaption>
        <p>
          <a href={`https://youtu.be/${videoId}`}>{title}</a>
          <span>Published: {date}</span>
          {isShort && <span>(short)</span>}
        </p>
        {description && <p>{description}</p>}
      </figcaption>
    )
  }
</figure>
<style>
  span {
    margin-inline-start: 1em;
  }
  figure :global(lite-youtube) {
    max-width: 600px;
    border-radius: 1em;
  }
</style>
