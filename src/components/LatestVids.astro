---
import { getCollection } from 'astro:content'
import { slugFromDay } from '@/lib/dates'

const latest = await getCollection('youtube', (entry) => {
  const pubDate = new Date(entry.data.publishedAt)
  const msSincePub = Date.now() - pubDate.getTime()
  const MS_PER_DAY = 1000 * 3600 * 24
  return msSincePub < MS_PER_DAY * 30
})
latest.sort((a, b) => -a.data.publishedAt.localeCompare(b.data.publishedAt))
---

<article>
  <h2>Latest Uploads</h2>
  <ul class="not-content">
    {
      latest.slice(0, 8).map((vid) => (
        <li>
          <a href={slugFromDay(vid.data.day)}>
            <img src={vid.data.thumbnails.high.url} />
            <span>{vid.data.title}</span>
          </a>
        </li>
      ))
    }
  </ul>
</article>

<style>
  ul {
    --b-rad: 8px;

    margin-inline: 0;
    padding-inline: 0;
    list-style: none;
    display: grid;
    /* responsive grid of thumbnails */
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    /* maximum of 3 rows (see also `overflow` on li) */
    grid-template-rows: repeat(3, auto);
    grid-auto-rows: 0px;

    /* column layout isn't half bad: */ 
    /* column-width: 12ch; */
    /* > li { break-inside: avoid; } */
  }
  li {
    overflow: hidden;
    /* would prefer `gap` on grid container, but it creates extra space for every "hidden" (implicit) row */
    margin: 4px;
    position: relative;
    color: var(--color-paper);
  }
  a {
    color: inherit;
  }
  a:not(:hover) {
    text-decoration: none;
  }
  img {
    --ratio: 16/9;
    width: 100%;
    aspect-ratio: var(--ratio);
    /* thumbnails are 4/3 with letterbox for some reason. crop out the letterbox. */
    object-fit: cover;
    /* need to get fancy because percentages create non-circular ellipses on non-square rectangles. */
    border-radius: var(--b-rad);
  }
  span {
    --margin: 3px;
    position: absolute;
    top: 0;
    left: 0;
    text-shadow: 0 0 .2em black;
    font-weight: 500;
    margin: var(--margin);
    padding: 0 .3em;
    background-color: hsl(none none 0% / 35%);
    line-height: 1.5em;
    border-top-left-radius: calc(var(--b-rad) - var(--margin));
  }
</style>
