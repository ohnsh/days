---
import Default from '@astrojs/starlight/components/Pagination.astro'
import Flexoki from '../../node_modules/starlight-theme-flexoki/overrides/Pagination.astro'

// A little hacky but works for now
const { page } = Astro.locals.days ?? {}
if (page) {
  const next = page.url.next ? { href: page.url.next } : undefined
  const prev = page.url.prev ? { href: page.url.prev } : undefined
  Astro.locals.starlightRoute.pagination = { next, prev }
}
---

<Flexoki />