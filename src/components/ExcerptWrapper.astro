---
import PostWrapper from './PostWrapper.astro'

interface Props {
  headingOffset: number
  fallback?: string
}

const { headingOffset, fallback = 'paragraph' } = Astro.props
const html = await Astro.slots.render('default')

// Excerpt delimeter (and overall component design) inspired by HiDeoo/starlight-blog
const excerptDelimeterIndex = html.indexOf(`<!-- excerpt -->`)
// ...but with fallback behavior if no delimeter found: just extract the first two paragraphs.
const fallbackIndex = computeFallbackIndex(html)

const excerpt =
  excerptDelimeterIndex === -1
    ? fallback !== 'paragraph' || fallbackIndex === Infinity
      ? html
      : html.slice(0, fallbackIndex)
    : html.slice(0, excerptDelimeterIndex)

function computeFallbackIndex(html: string, paragraphs = 2, greedy = true) {
  const startDiv1 = html.match(/<div[ >]/)
  const [endP2] = html.matchAll(/<\/p>/g).drop(paragraphs - 1)
  const greedyIndex = endP2 ? endP2.index + endP2[0].length : Infinity
  if (greedy) {
    return greedyIndex
  } else {
    return Math.min(startDiv1?.index ?? Infinity, greedyIndex)
  }
}
---

<PostWrapper {headingOffset}>
  <Fragment set:html={excerpt} />
</PostWrapper>
