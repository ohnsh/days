---
import type { CollectionEntry } from 'astro:content'
import VideoList from './VideoList.astro'

interface Props {
  categories: [string, CollectionEntry<'youtube'>[]][]
}

const { categories } = Astro.props
---

{
  categories.map(([tag, videos], i) => (
    <details open={i === 0}>
      <summary>{tag}</summary>
      <VideoList {videos} />
    </details>
  ))
}
