---
import { getEntry } from 'astro:content'
import { dateIdFromProp, dateIdFromAstroLocals, dateIdFromSlug } from '@/lib/util'

interface Props {
  date?: Date | string
}

const dateId =
  dateIdFromProp(Astro.props.date) ??
  dateIdFromSlug(Astro.url.pathname) ??
  dateIdFromAstroLocals(Astro.locals)
if (!dateId) {
  return
}
const entry = await getEntry('github', dateId)
if (!entry) {
  return
}
---

<article>
  <h3>Git Commits</h3>
  {
    entry.data.map(({ repo, commits }) => {
      const { html_url, created_at, updated_at, name } = repo
      return (
        <details>
          <summary>{name} commits</summary>
          <ul>
            {commits.map((commit) => {
              const {
                html_url,
                commit: { author, message },
              } = commit
              const { name, email, date } = author
              return (
                <li>
                  <p>
                    <a href={html_url}>At {date}</a>
                  </p>
                  <p>By {name}</p>
                  <p>{message}</p>
                </li>
              )
            })}
          </ul>
        </details>
      )
    })
  }
</article>
